.preview-stage {
  min-height: 320rpx;
  border-radius: 16rpx;
  background: #f7f1e8;
  border: 1rpx dashed #d8c9b5;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  text-align: center;
}

.preview-stage-label {
  color: #5d5044;
  line-height: 1.5;
  word-break: break-all;
}

.warning-item {
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: #f3e7d7;
  color: #684c2f;
}
