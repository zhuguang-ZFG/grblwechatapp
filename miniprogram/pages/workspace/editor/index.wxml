<view class="screen stack">
  <view class="section stack">
    <view class="split">
      <text class="section-title">实时预览</text>
      <button size="mini" class="ghost-btn" bindtap="togglePreview">{{showPreview ? '收起预览' : '展开预览'}}</button>
    </view>
    <view wx:if="{{showPreview}}" class="canvas-wrapper">
      <canvas type="2d" id="editorPreviewCanvas" class="preview-canvas" bindtouchstart="onCanvasTouchStart" catchtouchmove="onCanvasTouchMove" bindtouchend="onCanvasTouchEnd"></canvas>
      <text class="canvas-dim-label">{{project.layout.widthMm}} × {{project.layout.heightMm}} mm</text>
    </view>
  </view>

  <view class="section stack">
    <view class="field">
      <text class="label">项目名称</text>
      <input class="input" value="{{project.name}}" bindinput="onNameInput" />
    </view>

    <view class="field">
      <text class="label">内容类型</text>
      <view class="row">
        <button class="{{project.sourceType === 'text' ? 'primary-btn' : 'ghost-btn'}}" bindtap="setTextMode">文字</button>
        <button class="{{project.sourceType === 'image' ? 'secondary-btn' : 'ghost-btn'}}" bindtap="setImageMode">图片</button>
      </view>
    </view>

    <view wx:if="{{project.sourceType === 'text'}}" class="field">
      <text class="label">文字内容</text>
      <textarea class="textarea" value="{{project.content.text}}" bindinput="onTextInput" placeholder="输入要雕刻的文字" />
    </view>

    <view wx:if="{{project.sourceType === 'text'}}" class="field">
      <text class="label">字体</text>
      <picker mode="selector" range="{{fontOptions}}" range-key="name" value="{{fontIndex}}" bindchange="onFontChange">
        <view class="input">{{fontOptions[fontIndex].name || '选择字体'}}</view>
      </picker>
    </view>

    <view wx:if="{{project.sourceType === 'text'}}" class="row">
      <view class="field">
        <text class="label">字号(px)</text>
        <input class="input" type="digit" value="{{project.content.fontSize}}" data-field="fontSize" bindinput="onContentInput" />
      </view>
      <view class="field">
        <text class="label">行间距(px)</text>
        <input class="input" type="digit" value="{{project.content.lineGap}}" data-field="lineGap" bindinput="onContentInput" />
      </view>
    </view>

    <view wx:if="{{project.sourceType === 'text'}}" class="field">
      <text class="label">对齐方式</text>
      <view class="row">
        <button class="{{project.layout.align === 'left' ? 'primary-btn' : 'ghost-btn'}}" data-value="left" bindtap="onAlignChange">左对齐</button>
        <button class="{{project.layout.align === 'center' ? 'primary-btn' : 'ghost-btn'}}" data-value="center" bindtap="onAlignChange">居中</button>
        <button class="{{project.layout.align === 'right' ? 'primary-btn' : 'ghost-btn'}}" data-value="right" bindtap="onAlignChange">右对齐</button>
      </view>
    </view>

    <view wx:if="{{project.sourceType === 'text'}}" class="row">
      <view class="field">
        <text class="label">字距(px)</text>
        <input class="input" type="digit" value="{{project.content.charSpacing}}" data-field="charSpacing" bindinput="onContentInput" />
      </view>
      <view class="field">
        <text class="label">描边(px)</text>
        <input class="input" type="digit" value="{{project.content.strokeWidth}}" data-field="strokeWidth" bindinput="onContentInput" />
      </view>
      <view class="field">
        <text class="label">文本块宽(mm)</text>
        <input class="input" type="digit" value="{{project.layout.blockWidth}}" data-field="blockWidth" bindinput="onLayoutInput" />
      </view>
    </view>

    <view wx:else class="field">
      <text class="label">图片素材</text>
      <view class="input">{{project.content.imageAssetId || '未选择素材'}}</view>
      <button class="ghost-btn" bindtap="chooseImage">选择图片</button>
      <button class="ghost-btn" bindtap="mockUploadImage">使用示例图片</button>
    </view>

    <view wx:if="{{project.sourceType === 'image' && project.content.imageAssetId}}" class="section stack" style="margin-top: 16rpx;">
      <view class="split">
        <text class="section-title">裁剪区域 (mm)</text>
        <button class="ghost-btn" style="font-size: 24rpx; padding: 8rpx 12rpx;" bindtap="clearCrop">清除裁剪</button>
      </view>
      <view class="row">
        <view class="field">
          <text class="label">X</text>
          <input class="input" type="digit" value="{{project.content.cropBounds.x}}" data-field="x" bindinput="onCropInput" placeholder="0" />
        </view>
        <view class="field">
          <text class="label">Y</text>
          <input class="input" type="digit" value="{{project.content.cropBounds.y}}" data-field="y" bindinput="onCropInput" placeholder="0" />
        </view>
      </view>
      <view class="row">
        <view class="field">
          <text class="label">宽度</text>
          <input class="input" type="digit" value="{{project.content.cropBounds.width}}" data-field="width" bindinput="onCropInput" placeholder="全部" />
        </view>
        <view class="field">
          <text class="label">高度</text>
          <input class="input" type="digit" value="{{project.content.cropBounds.height}}" data-field="height" bindinput="onCropInput" placeholder="全部" />
        </view>
      </view>
    </view>

    <view wx:if="{{project.sourceType === 'image'}}" class="field">
      <text class="label">图片处理预设</text>
      <picker mode="selector" range="{{processorOptions}}" range-key="name" value="{{processorIndex}}" bindchange="onProcessorChange">
        <view class="input">{{processorOptions[processorIndex].name || '选择预设'}}</view>
      </picker>
    </view>
  </view>

  <view class="section stack">
    <text class="section-title">当前设备</text>
    <view class="split">
      <view class="stack" style="gap: 6rpx;">
        <text class="item-title">{{device.name || '未选择设备'}}</text>
        <text class="item-meta">{{device.model || '选择设备后项目将关联该设备生成参数'}}</text>
      </view>
      <text class="status-pill {{device.onlineStatus === 'online' ? 'status-pill-accent' : ''}}">{{device.onlineStatusLabel || '离线'}}</text>
    </view>
    <button class="ghost-btn" bindtap="goDevices">切换设备</button>
  </view>

  <view class="section stack">
    <text class="section-title">加工配置</text>
    <view class="field">
      <text class="label">机器配置文件</text>
      <picker mode="selector" range="{{machineProfileOptions}}" range-key="name" value="{{machineProfileIndex}}" bindchange="onMachineProfileChange">
        <view class="input">{{machineProfileOptions[machineProfileIndex].name || '选择配置'}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">材质预设</text>
      <picker mode="selector" range="{{materialProfileOptions}}" range-key="name" value="{{materialProfileIndex}}" bindchange="onMaterialProfileChange">
        <view class="input">{{materialProfileOptions[materialProfileIndex].name || '选择预设'}}</view>
      </picker>
    </view>
  </view>

  <view class="section stack">
    <text class="section-title">尺寸参数</text>
    <view class="row">
      <view class="field">
        <text class="label">宽度(mm)</text>
        <input class="input" type="digit" value="{{project.layout.widthMm}}" data-field="widthMm" bindinput="onLayoutInput" />
      </view>
      <view class="field">
        <text class="label">高度(mm)</text>
        <input class="input" type="digit" value="{{project.layout.heightMm}}" data-field="heightMm" bindinput="onLayoutInput" />
      </view>
      <view class="field">
        <text class="label">旋转(°)</text>
        <input class="input" type="digit" value="{{project.layout.rotationDeg}}" data-field="rotationDeg" bindinput="onLayoutInput" />
      </view>
    </view>
  </view>

  <view class="section stack">
    <text class="section-title">加工参数</text>
    <view class="row">
      <view class="field">
        <text class="label">速度</text>
        <input class="input" type="digit" value="{{project.processParams.speed}}" data-field="speed" bindinput="onParamInput" />
      </view>
      <view class="field">
        <text class="label">功率</text>
        <input class="input" type="digit" value="{{project.processParams.power}}" data-field="power" bindinput="onParamInput" />
      </view>
      <view class="field">
        <text class="label">加工次数</text>
        <input class="input" type="digit" value="{{project.processParams.passes}}" data-field="passes" bindinput="onParamInput" />
      </view>
    </view>
    <view class="row">
      <view class="field">
        <text class="label">行距(mm)</text>
        <input class="input" type="digit" value="{{project.processParams.lineSpacing}}" data-field="lineSpacing" bindinput="onParamInput" />
      </view>
    </view>
  </view>

  <view class="fixed-cta stack">
    <button class="ghost-btn" bindtap="showSaveTemplate">保存为模板</button>
    <button class="ghost-btn" bindtap="exportProject">导出项目</button>
    <button class="ghost-btn" bindtap="saveProject">保存</button>
    <button class="primary-btn" loading="{{loading}}" bindtap="generatePreview">生成预览</button>
  </view>

  <!-- Save as template overlay -->
  <view wx:if="{{showSaveTemplate}}" class="overlay" bindtap="cancelSaveTemplate">
    <view class="overlay-content" catchtap=""><view class="section stack">
      <text class="section-title">保存为模板</text>
      <view class="field">
        <text class="label">模板名称</text>
        <input class="input" value="{{templateName}}" bindinput="onTemplateNameInput" placeholder="输入模板名称" />
      </view>
      <view class="field">
        <text class="label">描述</text>
        <input class="input" value="{{templateDescription}}" bindinput="onTemplateDescInput" placeholder="输入模板描述（选填）" />
      </view>
      <view class="field">
        <text class="label">分类</text>
        <picker mode="selector" range="['自定义','礼品','标牌','工艺']" value="0" bindchange="onTemplateCategoryChange">
          <view class="input">{{templateCategory}}</view>
        </picker>
      </view>
      <view class="row" style="justify-content: flex-end; gap: 16rpx; margin-top: 20rpx;">
        <button class="ghost-btn" bindtap="cancelSaveTemplate">取消</button>
        <button class="primary-btn" bindtap="confirmSaveTemplate">确认保存</button>
      </view>
    </view></view>
  </view>
</view>
