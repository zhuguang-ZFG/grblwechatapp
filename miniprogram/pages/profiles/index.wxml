<view class="screen stack">
  <view class="section stack">
    <view class="row" style="gap: 16rpx;">
      <button class="{{tab === 'machine' ? 'primary-btn' : 'ghost-btn'}}" data-tab="machine" bindtap="switchTab">设备配置</button>
      <button class="{{tab === 'material' ? 'primary-btn' : 'ghost-btn'}}" data-tab="material" bindtap="switchTab">材料配置</button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中...</view>

  <!-- Machine profiles tab -->
  <view wx:elif="{{tab === 'machine'}}" class="card-list">
    <view wx:for="{{machineProfiles}}" wx:key="id" class="list-item" data-type="machine" data-id="{{item.id}}" bindtap="viewProfile">
      <view class="split">
        <view class="stack" style="gap: 6rpx;">
          <text class="item-title">{{item.name}}</text>
          <text class="item-meta">{{item.deviceModel}} · {{item.workArea.widthMm}}×{{item.workArea.heightMm}}mm</text>
        </view>
        <text class="status-pill">{{item.originMode}}</text>
      </view>
      <view wx:if="{{!item.isSystem}}" class="row" style="justify-content: flex-end; gap: 8rpx; margin-top: 8rpx;">
        <button class="ghost-btn" style="font-size: 24rpx; padding: 8rpx 16rpx; color: #ff6b6b;" data-type="machine" data-id="{{item.id}}" bindtap="deleteProfile">删除</button>
      </view>
    </view>
    <view class="list-item" style="justify-content: center;">
      <button class="ghost-btn" data-type="machine" bindtap="showCreateForm">+ 新建设备配置</button>
    </view>
  </view>

  <!-- Material profiles tab -->
  <view wx:elif="{{tab === 'material'}}" class="card-list">
    <view wx:for="{{materialProfiles}}" wx:key="id" class="list-item" data-type="material" data-id="{{item.id}}" bindtap="viewProfile">
      <view class="split">
        <view class="stack" style="gap: 6rpx;">
          <text class="item-title">{{item.name}}</text>
          <text class="item-meta">{{item.category}} · {{item.recommendedParams.speed}}mm/s {{item.recommendedParams.power}}% {{item.recommendedParams.passes}}次</text>
        </view>
        <text class="status-pill">{{item.isSystem ? '系统' : '自定义'}}</text>
      </view>
      <view wx:if="{{!item.isSystem}}" class="row" style="justify-content: flex-end; gap: 8rpx; margin-top: 8rpx;">
        <button class="ghost-btn" style="font-size: 24rpx; padding: 8rpx 16rpx; color: #ff6b6b;" data-type="material" data-id="{{item.id}}" bindtap="deleteProfile">删除</button>
      </view>
    </view>
    <view class="list-item" style="justify-content: center;">
      <button class="ghost-btn" data-type="material" bindtap="showCreateForm">+ 新建材料配置</button>
    </view>
  </view>

  <!-- Create overlay -->
  <view wx:if="{{showCreate}}" class="overlay" bindtap="cancelCreate">
    <view class="overlay-content" catchtap=""><view class="section stack">
      <text class="section-title">{{createType === 'machine' ? '新建设备配置' : '新建材料配置'}}</text>
      <view class="field">
        <text class="label">名称</text>
        <input class="input" value="{{createName}}" bindinput="onCreateNameInput" placeholder="输入名称" />
      </view>
      <view class="row" style="justify-content: flex-end; gap: 16rpx; margin-top: 20rpx;">
        <button class="ghost-btn" bindtap="cancelCreate">取消</button>
        <button class="primary-btn" bindtap="confirmCreate">创建</button>
      </view>
    </view></view>
  </view>
</view>
