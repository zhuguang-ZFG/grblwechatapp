page {
  background: #f3ede2;
  color: #201914;
  font-size: 28rpx;
  min-height: 100%;
}

.screen {
  padding: 28rpx 24rpx 44rpx;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hero-title {
  font-size: 54rpx;
  font-weight: 700;
  line-height: 1.08;
}

.hero-copy,
.muted {
  color: #6a5d50;
}

.eyebrow {
  font-size: 22rpx;
  color: #8b7863;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.section {
  background: #fbf8f3;
  border: 1rpx solid #ddd1bf;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(73, 52, 32, 0.06);
}

.section-title {
  font-size: 24rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  color: #7c6f60;
  margin-bottom: 18rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.label {
  font-size: 24rpx;
  color: #5f5449;
}

.input,
.picker,
.textarea {
  background: #f6efe5;
  border: 1rpx solid #d7c8b4;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.textarea {
  min-height: 180rpx;
}

.row {
  display: flex;
  gap: 16rpx;
}

.row > view,
.row > button {
  flex: 1;
}

.primary-btn,
.secondary-btn,
.ghost-btn,
.danger-btn {
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.2;
  padding: 22rpx 24rpx;
  font-weight: 600;
}

.primary-btn {
  background: #201914;
  color: #fbf8f3;
}

.secondary-btn {
  background: #d9b276;
  color: #201914;
}

.ghost-btn {
  background: #f7f1e8;
  color: #43362c;
  border: 1rpx solid #d7c8b4;
}

.danger-btn {
  background: #8a4c42;
  color: #fbf8f3;
}

.fixed-cta {
  position: sticky;
  bottom: 0;
  padding-top: 16rpx;
  background: linear-gradient(to bottom, rgba(243, 237, 226, 0), #f3ede2 28%);
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.list-item {
  background: #fbf8f3;
  border: 1rpx solid #ddd2c1;
  border-radius: 14rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(73, 52, 32, 0.05);
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
}

.item-meta {
  margin-top: 8rpx;
  color: #6e6356;
  font-size: 24rpx;
}

.status-pill {
  display: inline-block;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ece2d2;
  color: #4d4138;
  font-size: 22rpx;
}

.status-pill-accent {
  background: #201914;
  color: #fbf8f3;
}

.progress-track {
  height: 14rpx;
  background: #ddd2c1;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #1f1a17;
}

.inline-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.split {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.empty {
  padding: 36rpx 0;
  text-align: center;
  color: #7c6f60;
}

.project-item {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.project-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.project-meta-block {
  background: #f5efe6;
  border: 1rpx solid #e1d6c6;
  border-radius: 12rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.project-meta-label {
  font-size: 22rpx;
  color: #7c6f60;
}

.project-meta-value {
  font-size: 26rpx;
  color: #2f2823;
  word-break: break-all;
}

.hero-panel {
  position: relative;
  overflow: hidden;
  background: linear-gradient(145deg, #2d2119, #594232);
  color: #fbf8f3;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 18rpx 40rpx rgba(50, 34, 20, 0.16);
}

.hero-panel::after {
  content: "";
  position: absolute;
  right: -40rpx;
  top: -30rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
}

.hero-panel .hero-copy,
.hero-panel .muted,
.hero-panel .eyebrow {
  color: rgba(251, 248, 243, 0.76);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.stat-card {
  background: #f7f1e8;
  border: 1rpx solid #dfd0bd;
  border-radius: 14rpx;
  padding: 18rpx;
  min-height: 116rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
}

.stat-label {
  font-size: 22rpx;
  color: #8a7764;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #251c16;
  line-height: 1.15;
  word-break: break-word;
}

.soft-divider {
  height: 1rpx;
  background: #e6dbc9;
}

.page-note {
  font-size: 24rpx;
  color: #756757;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f0e6d7;
  color: #58493e;
  font-size: 22rpx;
}
